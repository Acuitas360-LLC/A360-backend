OPENAI_API_KEY=

# PostgreSQL (preferred)
# Option 1: full URL
DB_URI=

# Option 2: compose from parts
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=
DB_PASSWORD=

# Optional testing-only fallback full URL (used only if DB_URI and DB_* parts are missing)
TEST_DB_URI_FALLBACK=

# Set to true to enforce bearer token authentication for API endpoints.
AUTH_REQUIRED=false

# Azure AD / Entra app settings for id token verification.
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=

# Optional overrides (auto-derived from tenant by default).
AZURE_AD_ISSUER=
AZURE_AD_JWKS_URL=

# Frontend domain used for CORS allowlist.
FRONTEND_URL=http://localhost:3000